# ─────────────────────────────────────────────────────────────────
#  Project S.A.F.E. — Environment Variables
#  Copy to .env and fill in your real keys.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace-with-a-long-random-string-min-32-chars

# CORS — frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT Auth ──────────────────────────────────────────────────────
JWT_SECRET_KEY=another-long-random-secret-for-jwt-signing
JWT_EXPIRY_HOURS=24

# ── Deepgram (real-time transcription) ───────────────────────────
# Get your key at: https://console.deepgram.com
# Endpoint used: https://api.deepgram.com/v1/listen
DEEPGRAM_API_KEY=your_deepgram_api_key_here
USE_REAL_TRANSCRIPTION=0

# ── OpenAI (intent classification) ───────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Endpoint used: https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
USE_REAL_INTENT_MODEL=0

# ── Teammate ML models ────────────────────────────────────────────
SPECTRAL_MODEL_PATH=app/models/weights/spectral_model.pkl
INTENT_MODEL_PATH=app/models/weights/intent_model.pkl
USE_REAL_SPECTRAL_MODEL=0

# ── Score fusion weights (must sum to 1.0) ────────────────────────
SPECTRAL_WEIGHT=0.6
INTENT_WEIGHT=0.4
HIGH_RISK_THRESHOLD=70
PRANK_THRESHOLD=35

# ── Rate limiting ─────────────────────────────────────────────────
RATELIMIT_DEFAULT=60 per minute
RATELIMIT_ANALYZE=20 per minute
RATELIMIT_AUTH=10 per minute