# ─────────────────────────────────────────────
#  Project S.A.F.E. — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Flask core
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace-with-a-long-random-string

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Spectral Engine ──────────────────────────
# Deepgram: used for real-time audio transcription + speaker diarization
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# AssemblyAI: alternative transcription provider (optional)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Path to your teammate's trained spectral model file
# Expected: sklearn Pipeline or torch Module saved with joblib/pickle
SPECTRAL_MODEL_PATH=app/models/weights/spectral_model.pkl

# ── Intent Engine ─────────────────────────────
# OpenAI: used for NLP coercion/urgency classification
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Path to your teammate's trained NLP intent model
INTENT_MODEL_PATH=app/models/weights/intent_model.pkl

# ── Score Fusion ──────────────────────────────
# Weights must sum to 1.0
SPECTRAL_WEIGHT=0.6
INTENT_WEIGHT=0.4

# Thresholds that map final_score → risk_label
HIGH_RISK_THRESHOLD=70
PRANK_THRESHOLD=35

# ── Rate Limiting ─────────────────────────────
RATELIMIT_DEFAULT=60 per minute
RATELIMIT_ANALYZE=20 per minute

# ── Feature Flags ─────────────────────────────
# Set to 0 to force mock responses even in production
USE_REAL_SPECTRAL_MODEL=0
USE_REAL_INTENT_MODEL=0
USE_REAL_TRANSCRIPTION=0